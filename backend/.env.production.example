# ═══ Photo Delivery — Backend Produção ═══
# Copie este arquivo como .env na VPS e preencha os valores.

# ─── Banco de Dados (PostgreSQL na VPS) ───
DATABASE_URL=postgresql+asyncpg://photodelivery:SUA_SENHA_AQUI@localhost:5432/photodelivery

# ─── JWT (gere com: python3 -c "import secrets; print(secrets.token_urlsafe(32))") ───
SECRET_KEY=COLE_A_CHAVE_GERADA_AQUI
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Pastas (caminhos absolutos na VPS) ───
WATCH_FOLDER=/home/app/uploads/_incoming
UPLOAD_FOLDER=/home/app/uploads

# ─── App ───
BASE_URL=https://fotos.seudominio.com.br
API_PREFIX=/api/v1
CORS_ORIGINS=https://fotos.seudominio.com.br
