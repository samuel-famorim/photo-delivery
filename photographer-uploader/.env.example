# URL do backend na VPS (substitua pelo IP real)
API_URL=http://192.168.1.100

# Token de acesso (gere no backend: POST /api/v1/auth/login)
API_TOKEN=seu-access-token-aqui

# Pasta onde o Lightroom exporta os JPGs
# Windows: C:/Users/SeuNome/Pictures/LightroomExport
# Mac: /Users/seunome/Pictures/LightroomExport
WATCH_FOLDER=C:/LightroomExport

# (Opcional) Pasta para mover fotos já enviadas
# PROCESSED_FOLDER=C:/LightroomExport/processados
