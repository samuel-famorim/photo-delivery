# ═══ Photo Delivery — Variáveis Docker ═══
# Copie este arquivo como .env e preencha os valores.

# IP público da sua VPS Hostinger (ex: 192.168.1.100)
SERVER_IP=0.0.0.0

# Senha do banco PostgreSQL
DB_PASSWORD=gerar-uma-senha-forte-aqui

# Chave JWT (gere com: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=gerar-uma-chave-aqui
